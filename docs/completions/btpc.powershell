            [CompletionResult]::new('--creation-date', '--creation-date', [CompletionResultType]::ParameterName, 'Include an explicit Unix creation timestamp')
            [CompletionResult]::new('--entropy', '--entropy', [CompletionResultType]::ParameterName, 'Set deterministic, random, or omitted entropy policy')
            [CompletionResult]::new('--name', '--name', [CompletionResultType]::ParameterName, 'Override the torrent root name')
            [CompletionResult]::new('--symlinks', '--symlinks', [CompletionResultType]::ParameterName, 'Symbolic-link policy')
            [CompletionResult]::new('--special-files', '--special-files', [CompletionResultType]::ParameterName, 'Special-file policy')
