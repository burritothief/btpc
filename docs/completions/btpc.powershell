
using namespace System.Management.Automation
using namespace System.Management.Automation.Language

Register-ArgumentCompleter -Native -CommandName 'btpc' -ScriptBlock {
    param($wordToComplete, $commandAst, $cursorPosition)

    $commandElements = $commandAst.CommandElements
    $command = @(
        'btpc'
        for ($i = 1; $i -lt $commandElements.Count; $i++) {
            $element = $commandElements[$i]
            if ($element -isnot [StringConstantExpressionAst] -or
                $element.StringConstantType -ne [StringConstantType]::BareWord -or
                $element.Value.StartsWith('-') -or
                $element.Value -eq $wordToComplete) {
                break
        }
        $element.Value
    }) -join ';'

    $completions = @(switch ($command) {
        'btpc' {
            [CompletionResult]::new('--config', '--config', [CompletionResultType]::ParameterName, 'Use this configuration file when configuration loading is enabled')
            [CompletionResult]::new('--color', '--color', [CompletionResultType]::ParameterName, 'Control colored terminal output')
            [CompletionResult]::new('--no-config', '--no-config', [CompletionResultType]::ParameterName, 'Disable implicit and environment-selected configuration')
            [CompletionResult]::new('-v', '-v', [CompletionResultType]::ParameterName, 'Increase diagnostic verbosity; may be repeated')
            [CompletionResult]::new('--verbose', '--verbose', [CompletionResultType]::ParameterName, 'Increase diagnostic verbosity; may be repeated')
            [CompletionResult]::new('-q', '-q', [CompletionResultType]::ParameterName, 'Suppress human summaries, warnings, and progress')
            [CompletionResult]::new('--quiet', '--quiet', [CompletionResultType]::ParameterName, 'Suppress human summaries, warnings, and progress')
            [CompletionResult]::new('-h', '-h', [CompletionResultType]::ParameterName, 'Print help')
            [CompletionResult]::new('--help', '--help', [CompletionResultType]::ParameterName, 'Print help')
            [CompletionResult]::new('-V', '-V ', [CompletionResultType]::ParameterName, 'Print version')
            [CompletionResult]::new('--version', '--version', [CompletionResultType]::ParameterName, 'Print version')
            [CompletionResult]::new('create', 'create', [CompletionResultType]::ParameterValue, 'Create canonical v1, v2, or hybrid metainfo from a file or directory')
            [CompletionResult]::new('inspect', 'inspect', [CompletionResultType]::ParameterValue, 'Inspect validated metainfo without reading payload files')
            [CompletionResult]::new('validate', 'validate', [CompletionResultType]::ParameterValue, 'Validate metainfo structure without reading payload files')
            [CompletionResult]::new('verify', 'verify', [CompletionResultType]::ParameterValue, 'Verify payload files against metainfo hashes')
            [CompletionResult]::new('edit', 'edit', [CompletionResultType]::ParameterValue, 'Edit metainfo metadata without reading payload files')
            [CompletionResult]::new('magnet', 'magnet', [CompletionResultType]::ParameterValue, 'Print a deterministic magnet URI')
            [CompletionResult]::new('config', 'config', [CompletionResultType]::ParameterValue, 'Locate, inspect, validate, and update configuration')
            [CompletionResult]::new('completion', 'completion', [CompletionResultType]::ParameterValue, 'Generate, install, or uninstall shell completions')
            [CompletionResult]::new('completions', 'completions', [CompletionResultType]::ParameterValue, 'Deprecated alias for `btpc completion generate`')
            [CompletionResult]::new('manpage', 'manpage', [CompletionResultType]::ParameterValue, 'Generate the btpc(1) manual page on stdout')
            [CompletionResult]::new('help', 'help', [CompletionResultType]::ParameterValue, 'Print this message or the help of the given subcommand(s)')
            break
        }
        'btpc;create' {
            [CompletionResult]::new('--batch', '--batch', [CompletionResultType]::ParameterName, 'Versioned TOML batch manifest')
            [CompletionResult]::new('--mode', '--mode', [CompletionResultType]::ParameterName, 'Torrent protocol representation')
            [CompletionResult]::new('-o', '-o', [CompletionResultType]::ParameterName, 'Destination .torrent path (defaults beside the payload)')
            [CompletionResult]::new('--output', '--output', [CompletionResultType]::ParameterName, 'Destination .torrent path (defaults beside the payload)')
            [CompletionResult]::new('--output-dir', '--output-dir', [CompletionResultType]::ParameterName, 'Write batch outputs beneath this directory')
            [CompletionResult]::new('--jobs', '--jobs', [CompletionResultType]::ParameterName, 'Maximum concurrent batch creation jobs')
            [CompletionResult]::new('--preset', '--preset', [CompletionResultType]::ParameterName, 'Apply a named creation preset; may be repeated')
