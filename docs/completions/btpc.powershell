            [CompletionResult]::new('--target-pieces', '--target-pieces', [CompletionResultType]::ParameterName, 'Target approximate number of pieces for automatic selection')
            [CompletionResult]::new('--max-piece-length', '--max-piece-length', [CompletionResultType]::ParameterName, 'Cap target-based automatic piece length')
            [CompletionResult]::new('-a', '-a', [CompletionResultType]::ParameterName, 'Add a tracker as its own tier; may be repeated')
            [CompletionResult]::new('--tracker', '--tracker', [CompletionResultType]::ParameterName, 'Add a tracker as its own tier; may be repeated')
            [CompletionResult]::new('--tracker-tier', '--tracker-tier', [CompletionResultType]::ParameterName, 'Add one comma-separated tracker tier; may be repeated')
            [CompletionResult]::new('--tracker-alias', '--tracker-alias', [CompletionResultType]::ParameterName, 'Add a configured tracker alias; may be repeated')
            [CompletionResult]::new('--tracker-group', '--tracker-group', [CompletionResultType]::ParameterName, 'Add a configured tracker group; may be repeated')
