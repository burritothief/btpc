            [CompletionResult]::new('--json', '--json', [CompletionResultType]::ParameterName, 'Emit a versioned JSON result to stdout')
            [CompletionResult]::new('--pretty', '--pretty', [CompletionResultType]::ParameterName, 'Use the expanded human completion renderer')
            [CompletionResult]::new('--no-config', '--no-config', [CompletionResultType]::ParameterName, 'Disable implicit and environment-selected configuration')
            [CompletionResult]::new('-v', '-v', [CompletionResultType]::ParameterName, 'Increase diagnostic verbosity; may be repeated')
            [CompletionResult]::new('--verbose', '--verbose', [CompletionResultType]::ParameterName, 'Increase diagnostic verbosity; may be repeated')
            [CompletionResult]::new('-q', '-q', [CompletionResultType]::ParameterName, 'Suppress human summaries, warnings, and progress')
            [CompletionResult]::new('--quiet', '--quiet', [CompletionResultType]::ParameterName, 'Suppress human summaries, warnings, and progress')
            [CompletionResult]::new('-h', '-h', [CompletionResultType]::ParameterName, 'Print help')
            [CompletionResult]::new('--help', '--help', [CompletionResultType]::ParameterName, 'Print help')
            break
        }
        'btpc;inspect' {
